{
  "name": "@your-scope/backstage-plugin-aws-devops-agent-backend",
  "description": "Backstage backend plugin for AWS DevOps Agent: proxies recommendations, investigations, chat, and webhook-triggered investigations for the frontend tab.",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "keywords": [
    "backstage",
    "backstage-plugin",
    "aws",
    "devops-agent",
    "sre",
    "observability"
  ],
  "homepage": "https://github.com/your-org/backstage-plugin-aws-devops-agent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/backstage-plugin-aws-devops-agent",
    "directory": "plugins/devops-agent-backend"
  },
  "bugs": "https://github.com/your-org/backstage-plugin-aws-devops-agent/issues",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "devops-agent",
    "pluginPackages": [
      "@your-scope/backstage-plugin-aws-devops-agent",
      "@your-scope/backstage-plugin-aws-devops-agent-backend"
    ]
  },
  "configSchema": "config.d.ts",
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@aws-sdk/client-devops-agent": "3.1073.0",
    "@aws-sdk/credential-providers": "3.1073.0",
    "@backstage/backend-defaults": "^0.17.3",
    "@backstage/backend-plugin-api": "^1.9.2",
    "@backstage/catalog-client": "^1.16.0",
    "@backstage/errors": "^1.3.1",
    "@backstage/plugin-catalog-node": "^2.2.2",
    "@backstage/types": "^1.2.2",
    "express": "^4.14.0",
    "express-promise-router": "^4.1.0",
    "zod": "^3.25.76 || ^4.0.0"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.11.4",
    "@backstage/cli": "^0.36.3",
    "@types/express": "^4.17.6",
    "@types/supertest": "^2.0.12",
    "supertest": "^6.2.4"
  },
  "files": [
    "dist",
    "config.d.ts"
  ]
}
